## 三、接口定义

### 3.1 IRenderBackend - 渲染后端

```moonbit
/// 渲染后端接口 - 核心抽象
trait IRenderBackend {
  // ========== 生命周期 ==========
  /// 初始化后端
  fn initialize(self: IRenderBackend, config: BackendConfig) -> Result[Unit, String]
  /// 关闭后端
  fn shutdown(self: IRenderBackend) -> Unit
  
  // ========== Surface 管理 ==========
  /// 创建窗口 Surface（用于屏幕显示）
  fn create_window_surface(self: IRenderBackend, window: WindowHandle) -> Result[ISurface, String]
  /// 创建离屏 Surface（用于导出）
  fn create_offscreen_surface(self: IRenderBackend, width: Int, height: Int) -> Result[ISurface, String]
  /// 销毁 Surface
  fn destroy_surface(self: IRenderBackend, surface: ISurface) -> Unit
  
  // ========== 资源管理 ==========
  /// 创建图像资源
  fn create_image(self: IRenderBackend, data: ByteArray, width: Int, height: Int, format: ImageFormat) -> Result[IImage, String]
  /// 销毁图像资源
  fn destroy_image(self: IRenderBackend, image: IImage) -> Unit
  
  // ========== 能力查询 ==========
  /// 获取后端能力
  fn get_capabilities(self: IRenderBackend) -> BackendCapabilities
  /// 获取后端名称
  fn get_name(self: IRenderBackend) -> String
}

/// 后端配置
type BackendConfig = {
  /// 是否启用 GPU 加速
  use_gpu: Bool,
  /// 是否启用 VSync
  vsync: Bool,
  /// GPU 设备选择（多 GPU 时）
  device_index: Option[Int],
  /// 调试模式
  debug: Bool,
}

/// 后端能力
type BackendCapabilities = {
  /// 是否支持 GPU 加速
  gpu_accelerated: Bool,
  /// 最大纹理尺寸
  max_texture_size: Int,
  /// 支持的图像格式
  supported_formats: Array[ImageFormat],
  /// 支持的混合模式
  supported_blend_modes: Array[BlendMode],
  /// 是否支持离屏渲染
  offscreen_rendering: Bool,
}

/// 图像格式
type ImageFormat = RGBA8888 | BGRA8888 | RGB888 | A8

/// 窗口句柄（平台相关）
type WindowHandle Int
```

### 3.2 ISurface - 渲染目标

```moonbit
/// Surface - 渲染目标抽象
trait ISurface {
  // ========== 画布访问 ==========
  /// 获取绘图 Canvas
  fn get_canvas(self: ISurface) -> ICanvas
  /// 获取尺寸
  fn get_size(self: ISurface) -> (Int, Int)
  
  // ========== 呈现 ==========
  /// 呈现到屏幕（仅窗口 Surface）
  fn present(self: ISurface) -> Unit
  
  // ========== 导出 ==========
  /// 读取像素数据（用于导出）
  fn read_pixels(self: ISurface) -> ByteArray
  /// 保存为 PNG
  fn save_to_png(self: ISurface, filepath: String) -> Result[Unit, String]
  
  // ========== 生命周期 ==========
  /// 调整大小
  fn resize(self: ISurface, width: Int, height: Int) -> Unit
}
```

### 3.3 ICanvas - 绘图画布

```moonbit
/// Canvas - 绘图画布抽象
trait ICanvas {
  // ========== 变换 ==========
  /// 保存当前状态
  fn save(self: ICanvas) -> Unit
  /// 恢复上一状态
  fn restore(self: ICanvas) -> Unit
  /// 平移
  fn translate(self: ICanvas, dx: Double, dy: Double) -> Unit
  /// 缩放
  fn scale(self: ICanvas, sx: Double, sy: Double) -> Unit
  /// 旋转（弧度）
  fn rotate(self: ICanvas, angle: Double) -> Unit
  /// 设置变换矩阵
  fn set_transform(self: ICanvas, transform: Transform) -> Unit
  /// 获取当前变换
  fn get_transform(self: ICanvas) -> Transform
  
  // ========== 绘制 - 基础图形 ==========
  /// 清除画布
  fn clear(self: ICanvas, color: Color) -> Unit
  /// 绘制矩形
  fn draw_rect(self: ICanvas, rect: Rect, paint: Paint) -> Unit
  /// 绘制椭圆
  fn draw_ellipse(self: ICanvas, cx: Double, cy: Double, rx: Double, ry: Double, paint: Paint) -> Unit
  /// 绘制线条
  fn draw_line(self: ICanvas, x1: Double, y1: Double, x2: Double, y2: Double, paint: Paint) -> Unit
  /// 绘制路径
  fn draw_path(self: ICanvas, path: IPath, paint: Paint) -> Unit
  
  // ========== 绘制 - 图像 ==========
  /// 绘制图像
  fn draw_image(self: ICanvas, image: IImage, dst: Rect, src: Option[Rect]) -> Unit
  
  // ========== 绘制 - 文本 (P1) ==========
  /// 绘制文本
  fn draw_text(self: ICanvas, text: String, x: Double, y: Double, paint: Paint, font: Font) -> Unit
  
  // ========== 裁剪 ==========
  /// 矩形裁剪
  fn clip_rect(self: ICanvas, rect: Rect) -> Unit
  /// 路径裁剪
  fn clip_path(self: ICanvas, path: IPath) -> Unit
  /// 重置裁剪
  fn reset_clip(self: ICanvas) -> Unit
  
  // ========== 图层 ==========
  /// 保存图层（用于透明度/混合）
  fn save_layer(self: ICanvas, bounds: Option[Rect], paint: Option[Paint]) -> Unit
  /// 恢复图层
  fn restore_layer(self: ICanvas) -> Unit
}

/// 变换矩阵
type Transform = {
  a: Double,  // scaleX
  b: Double,  // skewY
  c: Double,  // skewX
  d: Double,  // scaleY
  e: Double,  // translateX
  f: Double,  // translateY
}

/// 矩形
type Rect = {
  x: Double,
  y: Double,
  width: Double,
  height: Double,
}

/// 颜色 (RGBA)
type Color = {
  r: Double,
  g: Double,
  b: Double,
  a: Double,
}
```

### 3.4 IPath - 路径

```moonbit
/// Path - 路径抽象
trait IPath {
  // ========== 构建路径 ==========
  /// 移动到
  fn move_to(self: IPath, x: Double, y: Double) -> Unit
  /// 直线到
  fn line_to(self: IPath, x: Double, y: Double) -> Unit
  /// 二次贝塞尔曲线
  fn quad_to(self: IPath, cx: Double, cy: Double, x: Double, y: Double) -> Unit
