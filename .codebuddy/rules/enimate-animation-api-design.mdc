## 三、Output → Animation（导入）

### 3.1 图片序列导入

```moonbit
/// 图片序列导入器
type ImageSequenceImporter {}

impl ImageSequenceImporter {
  /// 从图片序列创建动画
  fn import(
    self: ImageSequenceImporter,
    image_paths: Array[String],
    fps: Int,
  ) -> Result[Document, String] {
    // 创建文档
    let doc = Document::create(
      name: "Imported Animation",
      width: get_image_width(image_paths[0])?,
      height: get_image_height(image_paths[0])?,
      fps: fps,
    )
    
    // 为每张图片创建一帧
    for (idx, path) in image_paths.enumerate() {
      // 创建图层和帧
      let layer = doc.timeline.create_layer("Frame \(idx)")
      let frame = layer.create_keyframe(idx)
      
      // 添加图片资源
      let resource = doc.add_image_resource(path)
      
      // 创建图片实例
      let shape = ShapeInstance::from_image(resource.id)
      frame.add_shape(shape)
    }
    
    Ok(doc)
  }
}
```

### 3.2 SVG 导入

```moonbit
/// SVG 导入器
type SvgImporter {}

impl SvgImporter {
  /// 解析 SVG 并转换为 Shape
  fn import(self: SvgImporter, svg_content: String) -> Result[Array[Shape], String] {
    // 解析 SVG DOM
    let svg = parse_svg(svg_content)
    
    // 转换为 Enimate 图形
    let shapes = []
    for element in svg.children {
      match element.tag {
        case "rect" => shapes.push(self.convert_rect(element))
        case "ellipse" => shapes.push(self.convert_ellipse(element))
        case "path" => shapes.push(self.convert_path(element))
        case "g" => shapes.push(self.convert_group(element))
      }
    }
    
    Ok(shapes)
  }
}
```

