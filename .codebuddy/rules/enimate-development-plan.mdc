##### 2.2 Skia Bridge 示例
```c
// skia_bridge.h
#ifdef __cplusplus
extern "C" {
#endif

typedef struct SkiaCanvas SkiaCanvas;
typedef struct SkiaPath SkiaPath;

// Canvas
SkiaCanvas* skia_canvas_create(int width, int height);
void skia_canvas_destroy(SkiaCanvas* canvas);
void skia_canvas_clear(SkiaCanvas* canvas, uint32_t color);
void skia_canvas_draw_rect(SkiaCanvas* canvas, float x, float y, float w, float h, uint32_t color, float stroke_width);
void skia_canvas_flush(SkiaCanvas* canvas);

// Path
SkiaPath* skia_path_create();
void skia_path_destroy(SkiaPath* path);
void skia_path_move_to(SkiaPath* path, float x, float y);
void skia_path_line_to(SkiaPath* path, float x, float y);
void skia_path_close(SkiaPath* path);

// PNG Export (使用 Skia 内置编码)
int skia_canvas_save_to_png(SkiaCanvas* canvas, const char* filepath);

#ifdef __cplusplus
}
#endif
```

##### 2.3 MoonBit FFI 绑定
```moonbit
// skia_ffi.mbt
extern "c" fn skia_canvas_create(width: Int, height: Int) -> RawSkiaCanvas
extern "c" fn skia_canvas_destroy(canvas: RawSkiaCanvas) -> Unit
extern "c" fn skia_canvas_clear(canvas: RawSkiaCanvas, color: UInt32) -> Unit
extern "c" fn skia_canvas_draw_rect(canvas: RawSkiaCanvas, x: Double, y: Double, w: Double, h: Double, color: UInt32, stroke_width: Double) -> Unit
extern "c" fn skia_canvas_flush(canvas: RawSkiaCanvas) -> Unit

type RawSkiaCanvas Int

// 封装为 MoonBit 类型
type SkiaCanvas {
  priv raw: RawSkiaCanvas
  width: Int
  height: Int
}

impl ICanvas for SkiaCanvas with ICanvas {
  fn clear(color: Color) -> Unit {
    let color_value = color_to_u32(color)
    skia_canvas_clear(self.raw, color_value)
  }
  
  fn draw_rect(rect: Rect, paint: Paint) -> Unit {
    let color_value = color_to_u32(paint.color)
    skia_canvas_draw_rect(self.raw, rect.x, rect.y, rect.w, rect.h, color_value, paint.stroke_width)
  }
}
```

