## 四、后端实现规范

### 4.1 SkiaBackend

```moonbit
/// Skia 后端实现
type SkiaBackend {
  priv context: Option[SkiaContext],
  priv gpu_enabled: Bool,
  priv debug: Bool,
}

impl IRenderBackend for SkiaBackend {
  fn initialize(self: SkiaBackend, config: BackendConfig) -> Result[Unit, String] {
    if config.use_gpu {
      // 初始化 Skia GPU 上下文 (Vulkan/OpenGL/Metal)
      self.context = SkiaContext::create_gpu(config.device_index)
    } else {
      // 初始化 CPU 光栅化
      self.context = SkiaContext::create_cpu()
    }
    Ok(())
  }
  
  fn get_name(self: SkiaBackend) -> String {
    if self.gpu_enabled { "Skia (GPU)" } else { "Skia (CPU)" }
  }
  
  // ... 其他方法
}
```

