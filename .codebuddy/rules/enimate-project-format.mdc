## 六、MoonBit 数据结构映射

```moonbit
// document.mbt
type Document = {
  version: String,
  meta: DocumentMeta,
  stage: StageConfig,
  resources: Array[Resource],
  timeline: Timeline,
  variables: Option[Map[String, Variable]],
}

type DocumentMeta = {
  name: String,
  created_at: String,
  modified_at: String,
  author: Option[String],
  description: Option[String],
}

type StageConfig = {
  width: Int,
  height: Int,
  fps: Int,
  background_color: String,
  total_frames: Int,
}

// timeline.mbt
type Timeline = {
  layers: Array[Layer],
  current_frame: Int,
  current_layer: Int,
}

type Layer = {
  id: String,
  name: String,
  visible: Bool,
  locked: Bool,
  opacity: Double,
  blend_mode: BlendMode,
  frames: Map[Int, Frame],
}

type BlendMode =
  | Normal
  | Multiply
  | Screen
  | Overlay
  | Darken
  | Lighten

type Frame = {
  index: Int,
  is_keyframe: Bool,
  is_empty: Bool,
  label: Option[String],
  shapes: Array[ShapeInstance],
}

// shape.mbt
type ShapeInstance = {
  id: String,
  shape: Shape,
  style: Style,
  transform: Transform,
}

type Shape =
  | Rectangle(Double, Double, Double, Double, Option[CornerRadius])  // x, y, w, h, radius
  | Ellipse(Double, Double, Double, Double, Option[Double], Option[Double])  // cx, cy, rx, ry, start, sweep
  | Line(Double, Double, Double, Double)  // x1, y1, x2, y2
  | Path(String, Option[FillRule])  // d, fill_rule
  | Group(Array[Shape])
  | SymbolRef(String, Option[Map[String, ShapeInstance]])  // ref_id, overrides

type Transform = {
  translate_x: Double,
  translate_y: Double,
  scale_x: Double,
  scale_y: Double,
  rotation: Double,
  pivot: Option[{ x: Double, y: Double }>,
}

type Style = {
  fill: Option[Fill],
  stroke: Option[Stroke],
  opacity: Double,
}

type Fill =
  | ColorFill(String)  // color
  | GradientFill(GradientType, Array[GradientStop], Option[Double])  // type, colors, angle
  | ImageFill(String)  // resource_id

type Stroke = {
  color: String,
  width: Double,
  cap: StrokeCap,
  join: StrokeJoin,
}

type StrokeCap = Butt | Round | Square
type StrokeJoin = Miter | Round | Bevel
type FillRule = NonZero | EvenOdd
type GradientType = Linear | Radial
type GradientStop = { color: String, position: Double }
```

