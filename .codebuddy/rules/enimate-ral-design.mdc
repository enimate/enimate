## 五、后端工厂

```moonbit
/// 后端类型
type BackendType =
  | SkiaCPU        // Skia CPU 光栅化
  | SkiaGPU        // Skia GPU (Vulkan/OpenGL/Metal)
  | Vulkan         // 原生 Vulkan（未来）
  | DirectX12      // DirectX 12（未来，Windows）
  | Metal          // Metal（未来，macOS/iOS）

/// 后端工厂
fn create_backend(backend_type: BackendType) -> Result[IRenderBackend, String] {
  match backend_type {
    SkiaCPU => Ok(SkiaBackend::create_cpu())
    SkiaGPU => Ok(SkiaBackend::create_gpu())
    Vulkan => Err("Vulkan backend not implemented yet")
    DirectX12 => Err("DirectX12 backend not implemented yet")
    Metal => Err("Metal backend not implemented yet")
  }
}

/// 自动选择最佳后端
fn auto_select_backend() -> BackendType {
  // 优先级: SkiaGPU > SkiaCPU
  if has_gpu_available() {
    SkiaGPU
  } else {
    SkiaCPU
  }
}
```

