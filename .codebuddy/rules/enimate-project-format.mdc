## 七、序列化/反序列化

### 7.1 JSON 序列化

```moonbit
// 使用 MoonBit 内置 JSON 支持
fn document_to_json(doc: Document) -> String {
  // MoonBit JSON 序列化
  Json::encode(doc)
}

fn document_from_json(json: String) -> Result[Document, String] {
  Json::decode(json)
}
```

### 7.2 文件读写

```moonbit
fn save_document(doc: Document, path: String) -> Result[Unit, String] {
  let json = document_to_json(doc)
  // FFI 调用文件写入
  write_file(path, json)
}

fn load_document(path: String) -> Result[Document, String] {
  match read_file(path) {
    Ok(json) => document_from_json(json)
    Err(e) => Err("Failed to read file: \{e}")
  }
}
```

