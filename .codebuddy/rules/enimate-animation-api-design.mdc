## 四、API → Animation（程序化创建）

### 4.1 核心 API 设计

```moonbit
/// 动画编辑器 API
type AnimationAPI {
  priv doc: Document
}

impl AnimationAPI {
  // ========== 文档操作 ==========
  
  /// 创建新文档
  fn create_document(
    name: String,
    width: Int,
    height: Int,
    fps: Int,
  ) -> AnimationAPI {
    let doc = Document::create(name, width, height, fps)
    { doc }
  }
  
  /// 打开文档
  fn open_document(path: String) -> Result[AnimationAPI, String] {
    let doc = load_document(path)?
    Ok({ doc })
  }
  
  /// 保存文档
  fn save(self: AnimationAPI, path: String) -> Result[Unit, String] {
    save_document(self.doc, path)
  }
  
  // ========== 图层操作 ==========
  
  /// 创建图层
  fn create_layer(self: AnimationAPI, name: String) -> String {
    let layer = self.doc.timeline.create_layer(name)
    layer.id
  }
  
  /// 删除图层
  fn delete_layer(self: AnimationAPI, layer_id: String) -> Unit {
    self.doc.timeline.delete_layer(layer_id)
  }
  
  /// 重命名图层
  fn rename_layer(self: AnimationAPI, layer_id: String, name: String) -> Unit {
    self.doc.timeline.get_layer(layer_id).name = name
  }
  
  // ========== 关键帧操作 ==========
  
  /// 插入关键帧
  fn insert_keyframe(
    self: AnimationAPI,
    layer_id: String,
    frame_index: Int,
  ) -> String {
    let layer = self.doc.timeline.get_layer(layer_id)
    let frame = layer.create_keyframe(frame_index)
    frame.id
  }
  
  /// 删除关键帧
  fn delete_keyframe(
    self: AnimationAPI,
    layer_id: String,
    frame_index: Int,
  ) -> Unit {
    self.doc.timeline.get_layer(layer_id).delete_keyframe(frame_index)
  }
  
  // ========== 图形操作 ==========
  
  /// 添加矩形
  fn add_rectangle(
    self: AnimationAPI,
    layer_id: String,
    frame_index: Int,
    x: Double, y: Double,
    width: Double, height: Double,
    fill: Option[String],
    stroke: Option[StrokeConfig],
  ) -> String {
    let shape = ShapeInstance::rectangle(x, y, width, height)
    shape.style = Style::from_config(fill, stroke)
    
    let frame = self.get_frame(layer_id, frame_index)
    frame.add_shape(shape)
    shape.id
  }
  
  /// 添加椭圆
  fn add_ellipse(
    self: AnimationAPI,
    layer_id: String,
    frame_index: Int,
    cx: Double, cy: Double,
    rx: Double, ry: Double,
    fill: Option[String],
    stroke: Option[StrokeConfig],
  ) -> String {
    let shape = ShapeInstance::ellipse(cx, cy, rx, ry)
    shape.style = Style::from_config(fill, stroke)
    
    let frame = self.get_frame(layer_id, frame_index)
    frame.add_shape(shape)
    shape.id
  }
  
  /// 添加贝塞尔路径
  fn add_path(
    self: AnimationAPI,
    layer_id: String,
    frame_index: Int,
    path_data: String,  // SVG path d 属性格式
    fill: Option[String],
    stroke: Option[StrokeConfig],
  ) -> String {
    let shape = ShapeInstance::path(path_data)
    shape.style = Style::from_config(fill, stroke)
    
    let frame = self.get_frame(layer_id, frame_index)
    frame.add_shape(shape)
    shape.id
  }
  
  // ========== 变换操作 ==========
  
  /// 移动图形
  fn move_shape(
    self: AnimationAPI,
    shape_id: String,
    dx: Double, dy: Double,
  ) -> Unit {
    let shape = self.find_shape(shape_id)
    shape.transform.translate_x += dx
    shape.transform.translate_y += dy
  }
  
  /// 缩放图形
  fn scale_shape(
    self: AnimationAPI,
    shape_id: String,
    sx: Double, sy: Double,
  ) -> Unit {
    let shape = self.find_shape(shape_id)
    shape.transform.scale_x *= sx
    shape.transform.scale_y *= sy
  }
  
  /// 旋转图形
  fn rotate_shape(
    self: AnimationAPI,
    shape_id: String,
    angle: Double,  // 弧度
  ) -> Unit {
    let shape = self.find_shape(shape_id)
    shape.transform.rotation += angle
  }
  
  // ========== 样式操作 ==========
  
  /// 设置填充颜色
  fn set_fill_color(
    self: AnimationAPI,
    shape_id: String,
    color: String,  // RGBA 十六进制
  ) -> Unit {
    let shape = self.find_shape(shape_id)
    shape.style.fill = Some(ColorFill(color))
  }
  
  /// 设置描边
  fn set_stroke(
    self: AnimationAPI,
    shape_id: String,
    color: String,
    width: Double,
  ) -> Unit {
    let shape = self.find_shape(shape_id)
    shape.style.stroke = Some({
      color, width, cap: Round, join: Round
    })
  }
}
```

### 4.2 AI Agent 集成示例

```moonbit
/// AI Agent 可使用的简化 API
/// 示例：从自然语言描述创建动画

fn create_animation_from_description(desc: AnimationDescription) -> Document {
  let api = AnimationAPI::create_document(
    name: desc.name,
    width: 800,
    height: 600,
    fps: 12,
  )
  
  // 创建图层
  for layer_desc in desc.layers {
    let layer_id = api.create_layer(layer_desc.name)
    
    // 创建关键帧
    for frame_desc in layer_desc.keyframes {
      let frame_id = api.insert_keyframe(layer_id, frame_desc.index)
      
      // 添加图形
      for shape_desc in frame_desc.shapes {
        match shape_desc.shape_type {
          case "rectangle" => 
            api.add_rectangle(layer_id, frame_desc.index,
              shape_desc.x, shape_desc.y,
              shape_desc.width, shape_desc.height,
              shape_desc.fill, shape_desc.stroke)
          case "ellipse" =>
            api.add_ellipse(layer_id, frame_desc.index,
              shape_desc.cx, shape_desc.cy,
              shape_desc.rx, shape_desc.ry,
              shape_desc.fill, shape_desc.stroke)
          case "path" =>
            api.add_path(layer_id, frame_desc.index,
              shape_desc.path_data,
              shape_desc.fill, shape_desc.stroke)
        }
        
        // 应用变换
        if shape_desc.transform != None {
          let shape_id = api.get_last_shape_id(layer_id, frame_desc.index)
          let t = shape_desc.transform.unwrap()
          api.move_shape(shape_id, t.translate_x, t.translate_y)
          api.scale_shape(shape_id, t.scale_x, t.scale_y)
          api.rotate_shape(shape_id, t.rotation)
        }
      }
    }
  }
  
  api.doc
}
```

