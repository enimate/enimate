## 五、Animation → API（查询与分析）

### 5.1 查询 API

```moonbit
impl AnimationAPI {
  // ========== 信息查询 ==========
  
  /// 获取文档信息
  fn get_document_info(self: AnimationAPI) -> DocumentInfo {
    {
      name: self.doc.meta.name,
      width: self.doc.stage.width,
      height: self.doc.stage.height,
      fps: self.doc.stage.fps,
      total_frames: self.doc.stage.total_frames,
      layer_count: self.doc.timeline.layers.length(),
    }
  }
  
  /// 获取图层列表
  fn get_layers(self: AnimationAPI) -> Array[LayerInfo] {
    self.doc.timeline.layers.map(|layer| {
      {
        id: layer.id,
        name: layer.name,
        visible: layer.visible,
        keyframe_count: layer.frames.count(|f| f.is_keyframe),
      }
    })
  }
  
  /// 获取帧内容
  fn get_frame_content(
    self: AnimationAPI,
    layer_id: String,
    frame_index: Int,
  ) -> FrameContent {
    let frame = self.get_frame(layer_id, frame_index)
    {
      shapes: frame.shapes.map(|s| self.shape_to_info(s)),
    }
  }
  
  /// 获取图形详情
  fn get_shape_info(self: AnimationAPI, shape_id: String) -> ShapeInfo {
    let shape = self.find_shape(shape_id)
    {
      id: shape.id,
      type: shape.shape.type_name(),
      transform: shape.transform,
      style: shape.style,
    }
  }
  
  // ========== 动画分析 ==========
  
  /// 分析图形在时间轴上的变化
  fn analyze_shape_animation(
    self: AnimationAPI,
    shape_id: String,
  ) -> Array[KeyframeTransform] {
    // 遍历所有帧，找到该图形的变换变化
    let transforms = []
    for layer in self.doc.timeline.layers {
      for (frame_idx, frame) in layer.frames {
        let shape = frame.shapes.find(|s| s.id == shape_id)
        if shape != None {
          transforms.push({
            frame: frame_idx,
            transform: shape.unwrap().transform,
          })
        }
      }
    }
    transforms.sort_by(|a, b| a.frame - b.frame)
  }
  
  /// 检测动画循环
  fn detect_animation_loop(self: AnimationAPI) -> Option[Int] {
    // 分析最后一帧与第一帧的差异
    // 如果相似度高于阈值，认为有循环
  }
}
```

