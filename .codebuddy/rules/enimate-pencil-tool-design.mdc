### 4.4 位图层系统 (BitmapLayer)

#### 4.4.1 数据结构

```moonbit
/// 位图层（继承自基础 Layer）
type BitmapLayer <: Layer = {
  // 基础属性（继承）
  id: String,
  name: String,
  visible: Bool,
  locked: Bool,
  opacity: Double,
  blend_mode: BlendMode,
  
  // 位图特有属性
  raster: RasterData,        // 像素数据
  strokes: Array[BrushStroke], // 笔触记录（用于撤销）
  width: Int,
  height: Int,
}

/// 光栅数据
type RasterData {
  priv pixels: ByteArray     // RGBA 格式
  priv width: Int
  priv height: Int
}

/// 笔触记录（用于撤销/重做）
type BrushStroke = {
  points: Array[StrokePoint],
  brush_settings: BrushSettings,
  timestamp: Double,
}
```

#### 4.4.2 操作方法

```moonbit
impl BitmapLayer {
  /// 创建空位图层
  fn create(width: Int, height: Int, name: String) -> BitmapLayer {
    let pixels = ByteArray::new(width * height * 4)  // RGBA
    // 初始化为透明
    pixels.fill(0)
    
    {
      id: generate_id(),
      name,
      visible: true,
      locked: false,
      opacity: 1.0,
      blend_mode: Normal,
      raster: { pixels, width, height },
      strokes: [],
      width,
      height,
    }
  }
  
  /// 绘制笔触
  fn draw_stroke(
    self: BitmapLayer,
    stroke: BrushStroke,
    engine: BrushEngine,
  ) -> Unit {
    // 渲染笔触到光栅
    for point in stroke.points {
      engine.render_dab(self.raster, point)
    }
    // 记录笔触（用于撤销）
    self.strokes.push(stroke)
  }
  
  /// 撤销最后笔触
  fn undo_last_stroke(self: BitmapLayer) -> Bool {
    if self.strokes.length() == 0 {
      return false
    }
    self.strokes.pop()
    // 重新渲染所有笔触
    self.rerender()
    true
  }
  
  /// 重新渲染（撤销后）
  fn rerender(self: BitmapLayer) -> Unit {
    self.raster.clear()
    for stroke in self.strokes {
      let engine = BrushEngine::new(stroke.brush_settings)
      for point in stroke.points {
        engine.render_dab(self.raster, point)
      }
    }
  }
  
  /// 清空图层
  fn clear(self: BitmapLayer) -> Unit {
    self.raster.clear()
    self.strokes = []
  }
}
```

