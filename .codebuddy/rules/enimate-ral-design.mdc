### 3.5 Paint - 样式

```moonbit
/// Paint - 绘制样式
type Paint = {
  /// 填充或描边
  style: PaintStyle,
  /// 颜色（如果是纯色）
  color: Color,
  /// 填充（如果非纯色）
  fill: Option[Fill],
  /// 描边宽度
  stroke_width: Double,
  /// 描边端点
  stroke_cap: StrokeCap,
  /// 描边连接
  stroke_join: StrokeJoin,
  /// 透明度
  opacity: Double,
  /// 混合模式
  blend_mode: BlendMode,
  /// 抗锯齿
  antialias: Bool,
}

type PaintStyle = Fill | Stroke | FillAndStroke

type StrokeCap = Butt | Round | Square

type StrokeJoin = Miter | Round | Bevel

/// 填充类型
type Fill =
  | SolidFill(Color)
  | LinearGradientFill(LinearGradient)
  | RadialGradientFill(RadialGradient)
  | ImageFill(ImageFill)

type LinearGradient = {
  start: (Double, Double),
  end: (Double, Double),
  stops: Array[GradientStop],
}

type RadialGradient = {
  center: (Double, Double),
  radius: Double,
  stops: Array[GradientStop],
}

type GradientStop = {
  position: Double,
  color: Color,
}

type ImageFill = {
  image: IImage,
  mode: ImageFillMode,
}

type ImageFillMode = Stretch | Fill | Fit | Tile

/// 混合模式
type BlendMode =
  | Normal
  | Multiply
  | Screen
  | Overlay
  | Darken
  | Lighten
  | ColorDodge
  | ColorBurn
  | HardLight
  | SoftLight
  | Difference
  | Exclusion
```

