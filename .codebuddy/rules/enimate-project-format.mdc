# Enimate 工程文件格式设计

> 本文档定义 Enimate 项目的工程文件格式（`.enim`），供 AI 编程工具参考。

## 一、文件后缀名

- **后缀名**：`.enim`（Enimate 的缩写）
- **格式**：JSON 文本文件
- **编码**：UTF-8
- **示例**：`my-animation.enim`

---

## 二、设计原则

借鉴 Pencil 的 `.pen` 格式设计思想：

| 原则 | 说明 |
|------|------|
| JSON 结构 | 人类可读，易于调试和版本控制 |
| 唯一标识 | 每个实体有唯一 `id`，便于引用和修改 |
| 类型驱动 | 使用 `type` 字段区分不同实体类型 |
| 复用机制 | 支持 Symbol（元件）复用，减少重复数据 |
| 向前兼容 | 使用 `version` 字段，支持格式演进 |
| 最小化存储 | 引用共享资源，避免数据冗余 |

---

## 三、核心数据结构

### 3.1 文档根结构

```typescript
interface EnimateDocument {
  /** 格式版本，用于兼容性检查 */
  version: string;
  
  /** 项目元数据 */
  meta: DocumentMeta;
  
  /** 舞台设置 */
  stage: StageConfig;
  
  /** 资源库（图片、元件等） */
  resources: Resource[];
  
  /** 时间轴（图层列表） */
  timeline: Timeline;
  
  /** 变量定义（可选，用于主题/配色） */
  variables?: VariableMap;
}

interface DocumentMeta {
  /** 项目名称 */
  name: string;
  /** 创建时间（ISO 8601） */
  created_at: string;
  /** 最后修改时间 */
  modified_at: string;
  /** 作者 */
  author?: string;
  /** 描述 */
  description?: string;
}

interface StageConfig {
  /** 画布宽度（像素） */
  width: number;
  /** 画布高度（像素） */
  height: number;
  /** 帧率 */
  fps: number;
  /** 背景色（RGBA 十六进制） */
  background_color: string;
  /** 总帧数 */
  total_frames: number;
}
```

### 3.2 资源系统

```typescript
interface Resource {
  id: string;
  name: string;
  type: ResourceType;
}

type ResourceType = 
  | SymbolResource   // 元件（可复用的图形组合）
  | ImageResource    // 外部图片
  | AudioResource    // 音频（预留，MVP 不实现）
  ;

/** 元件资源 - 可复用的图形组合 */
interface SymbolResource extends Resource {
  type: "symbol";
  /** 元件类型 */
  symbol_type: "graphic" | "button" | "movie_clip";
  /** 元件内容（图形树） */
  content: ShapeNode[];
  /** 元件内部时间轴（movie_clip 类型） */
  inner_timeline?: Timeline;
}

/** 图片资源 */
interface ImageResource extends Resource {
  type: "image";
  /** 相对路径或 base64 */
  source: string;
  width: number;
  height: number;
}
```

### 3.3 时间轴结构

```typescript
interface Timeline {
  /** 图层列表（从上到下） */
  layers: Layer[];
  /** 当前帧索引（0-based） */
  current_frame: number;
  /** 当前图层索引 */
  current_layer: number;
}

interface Layer {
  /** 唯一标识 */
  id: string;
  /** 图层名称 */
  name: string;
  /** 可见性 */
  visible: boolean;
  /** 锁定状态 */
  locked: boolean;
  /** 透明度（0.0 - 1.0） */
  opacity: number;
  /** 混合模式 */
  blend_mode: BlendMode;
  /** 帧数据（Map: 帧索引 → 帧） */
  frames: { [frame_index: number]: Frame };
}

type BlendMode = 
  | "normal"
  | "multiply"
  | "screen"
  | "overlay"
  | "darken"
  | "lighten"
  ;

interface Frame {
  /** 帧索引 */
  index: number;
  /** 是否为关键帧 */
  is_keyframe: boolean;
  /** 是否为空白关键帧 */
  is_empty: boolean;
  /** 帧标签（可选） */
  label?: string;
  /** 图形实例列表 */
  shapes: ShapeInstance[];
}
```

### 3.4 图形系统

```typescript
/** 图形实例 - 在帧中的具体实例 */
interface ShapeInstance {
  /** 唯一标识 */
  id: string;
  /** 图形数据或资源引用 */
  shape: Shape | SymbolRef;
  /** 样式 */
  style: Style;
  /** 变换 */
  transform: Transform;
}

/** 变换矩阵 */
interface Transform {
  translate_x: number;
  translate_y: number;
  scale_x: number;
  scale_y: number;
  rotation: number;  // 弧度
  /** 变换中心点（归一化 0-1） */
  pivot?: { x: number; y: number };
}

/** 样式 */
interface Style {
  fill?: Fill;
  stroke?: Stroke;
  opacity: number;
}

type Fill = 
  | ColorFill
  | GradientFill
  | ImageFill
  ;

interface ColorFill {
  type: "color";
  color: string;  // RGBA 十六进制
}

interface GradientFill {
  type: "gradient";
  gradient_type: "linear" | "radial";
  colors: { color: string; position: number }[];
  /** 渐变角度（度） */
  angle?: number;
}

interface ImageFill {
  type: "image";
  resource_id: string;  // 引用 ImageResource.id
}

interface Stroke {
  color: string;
  width: number;
  cap: "butt" | "round" | "square";
  join: "miter" | "round" | "bevel";
}

/** 图形节点（用于元件内容） */
type ShapeNode = 
  | RectangleShape
  | EllipseShape
  | LineShape
  | PathShape
  | GroupShape
  | SymbolRef
  ;

interface RectangleShape {
  type: "rectangle";
  x: number;
  y: number;
  width: number;
  height: number;
  corner_radius?: number | [number, number, number, number];
}

interface EllipseShape {
  type: "ellipse";
  cx: number;  // 中心 x
  cy: number;  // 中心 y
  rx: number;  // x 半径
  ry: number;  // y 半径
  start_angle?: number;
  sweep_angle?: number;
}

interface LineShape {
  type: "line";
  x1: number;
  y1: number;
  x2: number;
  y2: number;
}

interface PathShape {
  type: "path";
  /** SVG Path 数据 */
  d: string;
  fill_rule?: "nonzero" | "evenodd";
}

interface GroupShape {
  type: "group";
  children: ShapeNode[];
}

/** 元件引用 */
interface SymbolRef {
  type: "symbol_ref";
  /** 引用 SymbolResource.id */
  ref: string;
  /** 实例覆盖（类似 .pen 的 descendants） */
  overrides?: { [path: string]: Partial<ShapeInstance> };
}
```

### 3.5 变量系统（可选）

```typescript
interface VariableMap {
  [name: string]: Variable;
}

interface Variable {
  type: "color" | "number" | "string";
  value: any;
  /** 变量描述 */
  description?: string;
}

// 使用示例
// variables: {
//   "color.primary": { type: "color", value: "#FF5733FF" },
//   "stroke.width": { type: "number", value: 2 }
// }
// 在样式中引用: "$color.primary"
```

