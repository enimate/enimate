## 二、Animation → Output（导出）

### 2.1 PNG 序列帧导出

```moonbit
/// PNG 序列帧导出器
type PngExporter {
  output_dir: String
  filename_pattern: String  // "frame_{:04d}.png"
}

impl PngExporter {
  /// 导出指定帧范围
  fn export_frames(
    self: PngExporter,
    doc: Document,
    start_frame: Int,
    end_frame: Int,
  ) -> Result[Unit, String] {
    for frame_idx in start_frame..end_frame {
      // 渲染帧
      let canvas = render_frame(doc, frame_idx)
      // 生成文件名
      let filename = self.filename_pattern.format(frame_idx)
      // 保存 PNG
      canvas.save_to_png("{self.output_dir}/{filename}")?
    }
    Ok(())
  }
}
```

